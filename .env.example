# Token0 Configuration

# Storage mode: "lite" or "full"
# lite  = SQLite + in-memory cache + local filesystem (zero dependencies, great for testing)
# full  = PostgreSQL + Redis + S3/MinIO (production-ready)
STORAGE_MODE=lite

# --- Lite mode settings ---
SQLITE_PATH=token0.db

# --- Full mode settings (only needed when STORAGE_MODE=full) ---
# DATABASE_URL=postgresql+asyncpg://token0:token0@localhost:5432/token0
# REDIS_URL=redis://localhost:6379/0
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=token0-images

# LLM Provider Keys (users can also pass per-request via X-Provider-Key header)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Auth
TOKEN0_MASTER_KEY=change-me-in-production
